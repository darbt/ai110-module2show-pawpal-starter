classDiagram
    %% PawPal+ class diagram — keep updated as implementation evolves.
 
 class Owner {
        +str name
        +str email
        +List~Pet~ pets
        +addPet(pet: Pet) void
        +editTask(pet: Pet, task: Task) void
    }

    class Pet {
        +str name
        +int age
        +List~Task~ tasks
        +addTask(task: Task) void
        +editTask(task: Task) void
    }

    class Task {
        +str title
        +str description
        +date dueDate
        +int duration
        +Priority priority
    }

    class Scheduler {
        +int availableMinutes
        +generatePlan(tasks: List~Task~) List~Task~
        +sortByPriority(tasks: List~Task~) List~Task~
        +filterByTime(tasks: List~Task~) List~Task~
        +explainPlan(plan: List~Task~) str
    }

    class Priority {
        <<enumeration>>
        HIGH
        MEDIUM
        LOW
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler ..> Task : schedules
    Task --> Priority : uses
  
  